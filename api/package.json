    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "fastify-plugin": "^4.5.1",
    "fastify": "^4.28.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.8"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "prisma": "^5.14.0",
