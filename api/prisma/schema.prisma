generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SALES
  PROCUREMENT
  FINANCE
  DELIVERY_MANAGER
  APPROVER
  SENIOR_APPROVER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum LineCategory {
  HARDWARE
  SOFTWARE
  LICENCE
  LABOUR_FIXED
  LABOUR_TM
  OTHER
}

enum LabourType {
  FIXED
  TIME_AND_MATERIAL
}

enum RfqStatus {
  RFQ_DRAFT
  RFQ_OPEN
  SUPPLIER_QUOTES_REQUESTED
  SUPPLIER_QUOTES_RECEIVED
  PRICING_IN_PROGRESS
  INTERNAL_REVIEW_PENDING
  APPROVED_FOR_CLIENT
  SENT_TO_CLIENT
  CLIENT_EVALUATING
  CLIENT_ACCEPTED
  PO_RECEIVED
  SUPPLIER_SELECTION_PENDING
  SUPPLIER_SELECTED
  PRO_FORMA_REQUESTED
  PRO_FORMA_RECEIVED
  REQUISITION_PENDING
  REQUISITION_APPROVED
  PAYMENT_PENDING
  PAID_TO_SUPPLIER
  DELIVERY_SCHEDULED
  IN_TRANSIT
  DELIVERED
  DELIVERY_CONFIRMED
  INVOICE_DRAFT
  INVOICE_ISSUED
  INVOICE_PAID
  CLOSED
  LOST
  CANCELLED
}

enum SupplierQuoteStatus {
  REQUESTED
  RECEIVED
  EXPIRED
}

enum ClientQuoteStatus {
  DRAFT
  SUBMITTED_FOR_REVIEW
  APPROVED
  REJECTED
  SENT
  ACCEPTED
  LOST
}

enum ApprovalEntityType {
  CLIENT_QUOTE
  REQUISITION
}

enum ApprovalDecision {
  APPROVED
  REJECTED
  PENDING
}

enum ProFormaStatus {
  REQUESTED
  RECEIVED
  OVERDUE
}

enum RequisitionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  EFT
  CREDIT_CARD
  CASH
  OTHER
}

enum DeliveryMethod {
  COURIER
  OWN_DELIVERY
  REMOTE
  COLLECTION
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  CONFIRMED
  PARTIAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum AttachmentEntityType {
  RFQ
  SUPPLIER_QUOTE
  CLIENT_QUOTE
  PURCHASE_ORDER
  PRO_FORMA
  DELIVERY_NOTE
  CLIENT_INVOICE
  REQUISITION
  SUPPLIER_PAYMENT
}

enum MarkupCategory {
  HARDWARE
  SOFTWARE
  LICENCE
  OTHER
  ALL
}

enum MasterStatus {
  ACTIVE
  INACTIVE
}

enum RfqType {
  RFQ
  RFP
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String
  lastName  String
  password  String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rfqs              Rfq[]              @relation("AccountManager")
  clients           Client[]           @relation("AccountManager")
  clientQuotes      ClientQuote[]      @relation("PreparedBy")
  approvedQuotes    ClientQuote[]      @relation("ApprovedBy")
  approvals         Approval[]
  deliveries        Delivery[]         @relation("Responsible")
  supplierAwards    SupplierAward[]
  requisitions      Requisition[]
  markupRules       MarkupRule[]
  attachments       Attachment[]
  notifications     Notification[]
  auditLogs         AuditLog[]
}

model Client {
  id                 String       @id @default(uuid())
  code               String?      @unique
  name               String
  type               String?
  registrationNumber String?
  vatNumber          String?
  billingAddress     Json
  deliveryAddress    Json?
  creditTerms        Int          @default(30)
  accountManagerId   String?
  accountManager     User?        @relation("AccountManager", fields: [accountManagerId], references: [id])
  status             ClientStatus @default(ACTIVE)
  notes              String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  contacts       Contact[]
  rfqs           Rfq[]
  clientInvoices ClientInvoice[]
  purchaseOrders PurchaseOrder[]
}

model Contact {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  firstName String
  lastName  String
  email     String
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  rfqs Rfq[] @relation("RfqContact")
}

model Supplier {
  id                 String         @id @default(uuid())
  code               String?        @unique
  name               String
  type               String?
  registrationNumber String?
  vatNumber          String?
  contactEmail       String?
  contactPhone       String?
  address            Json?
  paymentTerms       String?
  leadTimeDays       Int?
  preferredContact   String?
  preferredSupplier  Boolean        @default(false)
  status             SupplierStatus @default(ACTIVE)
  notes              String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  supplierQuotes   SupplierQuote[]
  supplierAwards   SupplierAward[]
  proFormaInvoices ProFormaInvoice[]
  supplierPayments SupplierPayment[]
  requisitions     Requisition[]
  materials        Material[]
}

model Rfq {
  id               String    @id @default(uuid())
  referenceNumber  String    @unique
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])
  contactId        String?
  contact          Contact?  @relation("RfqContact", fields: [contactId], references: [id])
  accountManagerId String?
  accountManager   User?     @relation("AccountManager", fields: [accountManagerId], references: [id])
  receivedDate     DateTime  @default(now())
  deadline         DateTime?
  description      String?
  type             RfqType   @default(RFQ)
  status           RfqStatus @default(RFQ_DRAFT)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lineItems        RfqLineItem[]
  supplierQuotes   SupplierQuote[]
  clientQuotes     ClientQuote[]
  purchaseOrders   PurchaseOrder[]
  supplierAwards   SupplierAward[]
  proFormaInvoices ProFormaInvoice[]
  requisitions     Requisition[]
  deliveries       Delivery[]
  clientInvoices   ClientInvoice[]
  attachments      Attachment[]     @relation("RfqAttachments")
}

model RfqLineItem {
  id          String       @id @default(uuid())
  rfqId       String
  rfq         Rfq          @relation(fields: [rfqId], references: [id])
  lineNumber  Int
  description String
  category    LineCategory
  quantity    Decimal      @db.Decimal(10, 2)
  unit        String       @default("Each")
  notes       String?
  createdAt   DateTime     @default(now())

  supplierQuoteLines SupplierQuoteLine[]
  quoteLines         QuoteLine[]
}

model SupplierQuote {
  id           String              @id @default(uuid())
  rfqId        String
  rfq          Rfq                 @relation(fields: [rfqId], references: [id])
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  quoteDate    DateTime            @default(now())
  validUntil   DateTime?
  paymentTerms String?
  leadTimeDays Int?
  currency     String              @default("ZAR")
  totalCost    Decimal             @default(0) @db.Decimal(12, 2)
  status       SupplierQuoteStatus @default(REQUESTED)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  lines         SupplierQuoteLine[]
  supplierAward SupplierAward?
  attachments   Attachment[]        @relation("SupplierQuoteAttachments")
}

model SupplierQuoteLine {
  id                String        @id @default(uuid())
  supplierQuoteId   String
  supplierQuote     SupplierQuote @relation(fields: [supplierQuoteId], references: [id])
  rfqLineItemId     String?
  rfqLineItem       RfqLineItem?  @relation(fields: [rfqLineItemId], references: [id])
  description       String
  quantity          Decimal       @db.Decimal(10, 2)
  unitCost          Decimal       @db.Decimal(12, 2)
  totalCost         Decimal       @db.Decimal(12, 2)
  notes             String?

  quoteLines QuoteLine[]
}

model ClientQuote {
  id               String            @id @default(uuid())
  rfqId            String
  rfq              Rfq               @relation(fields: [rfqId], references: [id])
  versionNumber    Int               @default(1)
  status           ClientQuoteStatus @default(DRAFT)
  defaultMarkupPct Decimal           @default(0) @db.Decimal(5, 2)
  validUntil       DateTime?
  terms            String?
  totalCost        Decimal           @default(0) @db.Decimal(12, 2)
  totalSell        Decimal           @default(0) @db.Decimal(12, 2)
  grossMargin      Decimal           @default(0) @db.Decimal(12, 2)
  grossMarginPct   Decimal           @default(0) @db.Decimal(5, 2)
  preparedById     String?
  preparedBy       User?             @relation("PreparedBy", fields: [preparedById], references: [id])
  approvedById     String?
  approvedBy       User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  sentAt           DateTime?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  lines          QuoteLine[]
  approvals      Approval[]
  purchaseOrders PurchaseOrder[]
  clientInvoices ClientInvoice[]
  attachments    Attachment[]    @relation("ClientQuoteAttachments")
}

model QuoteLine {
  id                    String             @id @default(uuid())
  clientQuoteId         String
  clientQuote           ClientQuote        @relation(fields: [clientQuoteId], references: [id])
  lineNumber            Int
  description           String
  category              LineCategory
  quantity              Decimal            @db.Decimal(10, 2)
  unit                  String             @default("Each")
  unitCost              Decimal            @default(0) @db.Decimal(12, 2)
  markupPct             Decimal            @default(0) @db.Decimal(5, 2)
  unitSell              Decimal            @default(0) @db.Decimal(12, 2)
  labourType            LabourType?
  labourRate            Decimal?           @db.Decimal(12, 2)
  labourHoursEstimated  Decimal?           @db.Decimal(8, 2)
  labourHoursActual     Decimal?           @db.Decimal(8, 2)
  labourFixedFee        Decimal?           @db.Decimal(12, 2)
  totalCost             Decimal            @default(0) @db.Decimal(12, 2)
  totalSell             Decimal            @default(0) @db.Decimal(12, 2)
  notes                 String?
  rfqLineItemId         String?
  rfqLineItem           RfqLineItem?       @relation(fields: [rfqLineItemId], references: [id])
  supplierQuoteLineId   String?
  supplierQuoteLine     SupplierQuoteLine? @relation(fields: [supplierQuoteLineId], references: [id])

  deliveryLines DeliveryLine[]
}

model MarkupRule {
  id             String         @id @default(uuid())
  category       MarkupCategory @default(ALL)
  defaultMarkupPct Decimal      @db.Decimal(5, 2)
  effectiveFrom  DateTime       @default(now())
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())
}

model PurchaseOrder {
  id             String      @id @default(uuid())
  rfqId          String
  rfq            Rfq         @relation(fields: [rfqId], references: [id])
  clientQuoteId  String
  clientQuote    ClientQuote @relation(fields: [clientQuoteId], references: [id])
  clientId       String
  client         Client      @relation(fields: [clientId], references: [id])
  poNumber       String
  poDate         DateTime
  poAmount       Decimal     @db.Decimal(12, 2)
  receivedById   String?
  receivedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())

  clientInvoices ClientInvoice[]
  attachments    Attachment[]    @relation("PurchaseOrderAttachments")
}

model SupplierAward {
  id              String        @id @default(uuid())
  rfqId           String
  rfq             Rfq           @relation(fields: [rfqId], references: [id])
  supplierQuoteId String        @unique
  supplierQuote   SupplierQuote @relation(fields: [supplierQuoteId], references: [id])
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  awardedById     String
  awardedBy       User          @relation(fields: [awardedById], references: [id])
  awardedAt       DateTime      @default(now())
  rationale       String?

  proFormaInvoices ProFormaInvoice[]
}

model ProFormaInvoice {
  id              String         @id @default(uuid())
  rfqId           String
  rfq             Rfq            @relation(fields: [rfqId], references: [id])
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  supplierAwardId String
  supplierAward   SupplierAward  @relation(fields: [supplierAwardId], references: [id])
  requestedAt     DateTime       @default(now())
  receivedAt      DateTime?
  amount          Decimal?       @db.Decimal(12, 2)
  currency        String         @default("ZAR")
  status          ProFormaStatus @default(REQUESTED)
  createdAt       DateTime       @default(now())

  requisitions Requisition[]
  attachments  Attachment[]  @relation("ProFormaAttachments")
}

model Requisition {
  id                String            @id @default(uuid())
  rfqId             String
  rfq               Rfq               @relation(fields: [rfqId], references: [id])
  proFormaInvoiceId String
  proFormaInvoice   ProFormaInvoice   @relation(fields: [proFormaInvoiceId], references: [id])
  supplierId        String
  supplier          Supplier          @relation(fields: [supplierId], references: [id])
  requestedById     String
  requestedBy       User              @relation(fields: [requestedById], references: [id])
  requestedAt       DateTime          @default(now())
  amount            Decimal           @db.Decimal(12, 2)
  description       String?
  status            RequisitionStatus @default(DRAFT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  approvals        Approval[]
  supplierPayments SupplierPayment[]
  attachments      Attachment[]      @relation("RequisitionAttachments")
}

model Approval {
  id          String             @id @default(uuid())
  entityType  ApprovalEntityType
  entityId    String
  approverId  String
  approver    User               @relation(fields: [approverId], references: [id])
  decision    ApprovalDecision   @default(PENDING)
  comments    String?
  decidedAt   DateTime?
  level       Int                @default(1)
  createdAt   DateTime           @default(now())

  clientQuote ClientQuote? @relation(fields: [entityId], references: [id], map: "approval_client_quote")
  requisition Requisition? @relation(fields: [entityId], references: [id], map: "approval_requisition")
}

model SupplierPayment {
  id            String        @id @default(uuid())
  requisitionId String
  requisition   Requisition   @relation(fields: [requisitionId], references: [id])
  supplierId    String
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime
  paymentMethod PaymentMethod @default(EFT)
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())

  attachments Attachment[] @relation("SupplierPaymentAttachments")
}

model Delivery {
  id                String         @id @default(uuid())
  rfqId             String
  rfq               Rfq            @relation(fields: [rfqId], references: [id])
  method            DeliveryMethod @default(OWN_DELIVERY)
  scheduledDate     DateTime?
  actualDate        DateTime?
  responsibleUserId String?
  responsibleUser   User?          @relation("Responsible", fields: [responsibleUserId], references: [id])
  status            DeliveryStatus @default(SCHEDULED)
  isPartial         Boolean        @default(false)
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  lines        DeliveryLine[]
  deliveryNote DeliveryNote?
}

model DeliveryLine {
  id                String    @id @default(uuid())
  deliveryId        String
  delivery          Delivery  @relation(fields: [deliveryId], references: [id])
  quoteLineId       String
  quoteLine         QuoteLine @relation(fields: [quoteLineId], references: [id])
  description       String
  quantityDelivered Decimal   @db.Decimal(10, 2)
}

model DeliveryNote {
  id                  String   @id @default(uuid())
  deliveryId          String   @unique
  delivery            Delivery @relation(fields: [deliveryId], references: [id])
  confirmedAt         DateTime @default(now())
  confirmedByName     String
  confirmedByContact  String?
  notes               String?
  createdAt           DateTime @default(now())

  clientInvoices ClientInvoice[]
  attachments    Attachment[]    @relation("DeliveryNoteAttachments")
}

model ClientInvoice {
  id              String        @id @default(uuid())
  rfqId           String
  rfq             Rfq           @relation(fields: [rfqId], references: [id])
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  clientQuoteId   String
  clientQuote     ClientQuote   @relation(fields: [clientQuoteId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  deliveryNoteId  String?
  deliveryNote    DeliveryNote? @relation(fields: [deliveryNoteId], references: [id])
  invoiceNumber   String        @unique
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime
  totalAmount     Decimal       @db.Decimal(12, 2)
  status          InvoiceStatus @default(DRAFT)
  paidAt          DateTime?
  paidAmount      Decimal?      @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  attachments Attachment[] @relation("ClientInvoiceAttachments")
}

model Attachment {
  id           String               @id @default(uuid())
  entityType   AttachmentEntityType
  entityId     String
  fileName     String
  fileSize     Int
  mimeType     String
  storageUrl   String
  uploadedById String
  uploadedBy   User                 @relation(fields: [uploadedById], references: [id])
  uploadedAt   DateTime             @default(now())

  rfq              Rfq?              @relation("RfqAttachments", fields: [entityId], references: [id], map: "attachment_rfq")
  supplierQuote    SupplierQuote?    @relation("SupplierQuoteAttachments", fields: [entityId], references: [id], map: "attachment_supplier_quote")
  clientQuote      ClientQuote?      @relation("ClientQuoteAttachments", fields: [entityId], references: [id], map: "attachment_client_quote")
  purchaseOrder    PurchaseOrder?    @relation("PurchaseOrderAttachments", fields: [entityId], references: [id], map: "attachment_po")
  proForma         ProFormaInvoice?  @relation("ProFormaAttachments", fields: [entityId], references: [id], map: "attachment_proforma")
  deliveryNote     DeliveryNote?     @relation("DeliveryNoteAttachments", fields: [entityId], references: [id], map: "attachment_delivery_note")
  clientInvoice    ClientInvoice?    @relation("ClientInvoiceAttachments", fields: [entityId], references: [id], map: "attachment_invoice")
  requisition      Requisition?      @relation("RequisitionAttachments", fields: [entityId], references: [id], map: "attachment_requisition")
  supplierPayment  SupplierPayment?  @relation("SupplierPaymentAttachments", fields: [entityId], references: [id], map: "attachment_payment")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  message    String
  entityType String
  entityId   String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())
}

// ─── Master Data ──────────────────────────────────────────────────────────────

model Department {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  description String?
  managerId   String?
  manager     Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  status      MasterStatus @default(ACTIVE)
  notes       String?
  createdById String?
  updatedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  employees Employee[]
}

model Employee {
  id             String       @id @default(uuid())
  employeeNumber String       @unique
  firstName      String
  lastName       String
  email          String       @unique
  phone          String?
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  jobTitle       String?
  managerId      String?
  manager        Employee?    @relation("Reports", fields: [managerId], references: [id])
  directReports  Employee[]   @relation("Reports")
  employmentType String?
  costRate       Decimal?     @db.Decimal(12, 2)
  billableRate   Decimal?     @db.Decimal(12, 2)
  status         MasterStatus @default(ACTIVE)
  notes          String?
  createdById    String?
  updatedById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  managedDepartments Department[] @relation("DepartmentManager")
}

model Material {
  id                   String       @id @default(uuid())
  code                 String       @unique
  name                 String
  description          String?
  category             String?
  unitOfMeasure        String       @default("Each")
  defaultCost          Decimal?     @db.Decimal(12, 2)
  defaultSellingPrice  Decimal?     @db.Decimal(12, 2)
  defaultMarkupPercent Decimal?     @db.Decimal(5, 2)
  preferredSupplierId  String?
  preferredSupplier    Supplier?    @relation(fields: [preferredSupplierId], references: [id])
  taxCode              String?
  status               MasterStatus @default(ACTIVE)
  notes                String?
  createdById          String?
  updatedById          String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model ServiceItem {
  id              String       @id @default(uuid())
  code            String       @unique
  name            String
  description     String?
  category        String?
  pricingType     String       @default("FIXED")
  unitOfMeasure   String       @default("Hour")
  defaultCostRate Decimal?     @db.Decimal(12, 2)
  defaultBillRate Decimal?     @db.Decimal(12, 2)
  standardHours   Decimal?     @db.Decimal(8, 2)
  taxCode         String?
  status          MasterStatus @default(ACTIVE)
  notes           String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}
